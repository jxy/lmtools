{
  "provider": "anthropic",
  "model": "claude-test",
  "steps": [
    {
      "id": "create-first-response",
      "method": "POST",
      "path": "/v1/responses",
      "body": {
        "model": "claude-test",
        "input": "hello",
        "store": true
      },
      "upstream": {
        "body": "mock/anthropic-first.response.json"
      },
      "expect": {
        "status": 200,
        "json_fields": {
          "object": "response",
          "status": "completed",
          "output.0.type": "message",
          "output.0.content.0.text": "first answer"
        }
      },
      "backend_requests": [
        {
          "method": "POST",
          "path": "/messages",
          "body_contains": [
            "hello"
          ],
          "body_not_contains": [
            "first answer"
          ]
        }
      ],
      "bind": {
        "first_response_id": "id"
      }
    },
    {
      "id": "follow-up-with-previous-response",
      "method": "POST",
      "path": "/v1/responses",
      "body": {
        "model": "claude-test",
        "previous_response_id": "${first_response_id}",
        "input": "next"
      },
      "upstream": {
        "body": "mock/anthropic-second.response.json"
      },
      "expect": {
        "status": 200,
        "json_fields": {
          "status": "completed",
          "output.0.content.0.text": "second answer"
        }
      },
      "backend_requests": [
        {
          "method": "POST",
          "path": "/messages",
          "body_contains": [
            "hello",
            "first answer",
            "next"
          ]
        }
      ]
    },
    {
      "id": "retrieve-first-response",
      "method": "GET",
      "path": "/v1/responses/${first_response_id}",
      "expect": {
        "status": 200,
        "json_fields": {
          "id": "${first_response_id}",
          "object": "response",
          "status": "completed",
          "output.0.content.0.text": "first answer"
        }
      }
    },
    {
      "id": "list-first-input-items",
      "method": "GET",
      "path": "/v1/responses/${first_response_id}/input_items",
      "expect": {
        "status": 200,
        "json_fields": {
          "object": "list",
          "data.length": 1,
          "data.0.type": "message",
          "data.0.role": "user",
          "data.0.content.0.type": "input_text",
          "data.0.content.0.text": "hello"
        }
      }
    }
  ]
}
