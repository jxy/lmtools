{
  "provider": "anthropic",
  "model": "claude-test",
  "steps": [
    {
      "id": "create-background-response",
      "method": "POST",
      "path": "/v1/responses",
      "body": {
        "model": "claude-test",
        "input": "background work",
        "background": true
      },
      "upstream": {
        "body": "mock/anthropic-background.response.json"
      },
      "expect": {
        "status": 200,
        "json_fields": {
          "object": "response",
          "status": "queued",
          "output.length": 0
        }
      },
      "backend_requests": [
        {
          "method": "POST",
          "path": "/messages",
          "body_contains": [
            "background work"
          ]
        }
      ],
      "bind": {
        "response_id": "id"
      }
    },
    {
      "id": "retrieve-completed-background-response",
      "method": "GET",
      "path": "/v1/responses/${response_id}",
      "poll_until": {
        "status": "completed",
        "output.0.content.0.text": "background answer"
      },
      "capture_poll_until": {
        "status": "completed"
      },
      "expect": {
        "status": 200,
        "json_fields": {
          "id": "${response_id}",
          "status": "completed",
          "output.0.content.0.text": "background answer"
        }
      }
    }
  ]
}
