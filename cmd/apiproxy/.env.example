# API Keys
ANTHROPIC_API_KEY=your-anthropic-key-here  # Optional, only if proxying TO Anthropic
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# Argo Configuration
ARGO_USER=your-argo-username
ARGO_ENV=dev  # Options: prod, dev, or custom URL

# Provider Configuration
PREFERRED_PROVIDER=openai  # Options: openai, google, argo

# Model Mapping
# These models will be used when Claude haiku/sonnet models are requested
BIG_MODEL=gpt-4.1          # For sonnet models
SMALL_MODEL=gpt-4.1-mini   # For haiku models

# Example configurations for different providers:

# OpenAI Setup
# PREFERRED_PROVIDER=openai
# BIG_MODEL=gpt-4o
# SMALL_MODEL=gpt-4o-mini

# Google Gemini Setup
# PREFERRED_PROVIDER=google
# BIG_MODEL=gemini-2.5-pro-preview-03-25
# SMALL_MODEL=gemini-2.0-flash

# Argo Setup
# PREFERRED_PROVIDER=argo
# BIG_MODEL=claudesonnet4
# SMALL_MODEL=gemini25flash